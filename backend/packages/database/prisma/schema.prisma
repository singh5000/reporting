// =============================================================================
// 360CRD - Enterprise EHS & Compliance Management Platform
// Prisma Schema - Row-Based Multi-Tenant Architecture
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("DATABASE_SHADOW_URL")
}

// =============================================================================
// TENANT MANAGEMENT
// =============================================================================

model Tenant {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  legalName   String?
  domain      String?      @unique
  subdomain   String?      @unique
  plan        TenantPlan   @default(STARTER)
  status      TenantStatus @default(TRIAL)
  industry    String?
  country     String?
  timezone    String       @default("UTC")
  locale      String       @default("en")
  maxUsers    Int          @default(50)
  maxSites    Int          @default(10)
  trialEndsAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  branding          TenantBranding?
  config            TenantConfig?
  smtp              TenantSmtp?
  users             User[]
  roles             Role[]
  sites             Site[]
  customers         Customer[]
  incidents         Incident[]
  auditTemplates    AuditTemplate[]
  audits            Audit[]
  trainings         Training[]
  inductions        Induction[]
  ppeItems          PPEItem[]
  assets            Asset[]
  wasteRecords      WasteRecord[]
  documents         Document[]
  notifications     Notification[]
  notifTemplates    NotificationTemplate[]
  reports           Report[]
  activityLogs      ActivityLog[]
  auditLogs         AuditLog[]
  apiKeys           ApiKey[]
  webhooks          Webhook[]
  feedbacks         Feedback[]

  @@index([slug])
  @@index([domain])
  @@index([status])
  @@map("tenants")
}

model TenantBranding {
  id             String   @id @default(cuid())
  tenantId       String   @unique
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appName        String?
  primaryColor   String   @default("#2563EB")
  secondaryColor String   @default("#7C3AED")
  accentColor    String?
  textColor      String   @default("#111827")
  logoUrl        String?
  faviconUrl     String?
  loginBgUrl     String?
  supportEmail   String?
  supportPhone   String?
  website        String?
  footerText     String?
  customCss      String?  @db.Text
  emailHeader    String?  @db.Text
  emailFooter    String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("tenant_brandings")
}

model TenantConfig {
  id                   String   @id @default(cuid())
  tenantId             String   @unique
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  features             Json     @default("{}")
  mfaRequired          Boolean  @default(false)
  sessionTimeoutMins   Int      @default(480)
  maxLoginAttempts     Int      @default(5)
  passwordPolicy       Json     @default("{\"minLength\":8,\"requireUppercase\":true,\"requireNumber\":true,\"requireSpecial\":true}")
  fileStorageProvider  String   @default("s3")
  storageRegion        String?
  storageBucket        String?
  storagePrefix        String?
  maxFileSizeMb        Int      @default(50)
  allowedFileTypes     String[] @default(["pdf", "jpg", "jpeg", "png", "docx", "xlsx"])
  notifChannels        String[] @default(["email", "push", "in-app"])
  incidentCategories   String[] @default(["Safety", "Environmental", "Quality", "Security"])
  riskMatrix           Json     @default("{}")
  workingHours         Json     @default("{}")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("tenant_configs")
}

model TenantSmtp {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  host        String
  port        Int      @default(587)
  secure      Boolean  @default(true)
  username    String
  password    String
  fromEmail   String
  fromName    String
  replyTo     String?
  isVerified  Boolean  @default(false)
  verifiedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("tenant_smtps")
}

// =============================================================================
// USERS & IDENTITY
// =============================================================================

model User {
  id                  String     @id @default(cuid())
  tenantId            String
  tenant              Tenant     @relation(fields: [tenantId], references: [id])
  email               String
  emailVerified       Boolean    @default(false)
  emailVerifiedAt     DateTime?
  phone               String?
  phoneVerified       Boolean    @default(false)
  passwordHash        String
  firstName           String
  lastName            String
  avatarUrl           String?
  status              UserStatus @default(ACTIVE)
  type                UserType   @default(STAFF)
  department          String?
  jobTitle            String?
  employeeId          String?
  mfaEnabled          Boolean    @default(false)
  mfaSecret           String?
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  lastLoginIp         String?
  passwordChangedAt   DateTime?
  mustChangePassword  Boolean    @default(false)
  metadata            Json?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  deletedAt           DateTime?

  roles                UserRole[]
  sessions             Session[]
  refreshTokens        RefreshToken[]
  devices              UserDevice[]
  otpCodes             OTPCode[]
  sites                UserSite[]
  reportedIncidents    Incident[]           @relation("IncidentReporter")
  assignedIncidents    Incident[]           @relation("IncidentAssignee")
  incidentCapas        IncidentCAPA[]       @relation("CAPAAssignee")
  incidentCapaVerifier IncidentCAPA[]       @relation("CAPAVerifier")
  assignedAudits       Audit[]              @relation("AuditAssignee")
  completedAudits      Audit[]              @relation("AuditCompletedBy")
  trainingEnrollments  TrainingEnrollment[]
  inductionEnrollments InductionEnrollment[]
  ppeAssignments       PPEAssignment[]
  assetAssignments     AssetAssignment[]
  uploadedDocuments    Document[]
  activityLogs         ActivityLog[]
  notifications        Notification[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@index([status])
  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  name        String
  slug        String
  description String?
  isSystem    Boolean  @default(false)
  isDefault   Boolean  @default(false)
  level       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  users       UserRole[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id          String          @id @default(cuid())
  resource    String
  action      String
  scope       PermissionScope @default(TENANT)
  description String?
  createdAt   DateTime        @default(now())

  roles RolePermission[]

  @@unique([resource, action, scope])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  conditions   Json?
  grantedAt    DateTime   @default(now())
  grantedBy    String?

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId     String
  roleId     String
  tenantId   String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  siteId     String?
  assignedAt DateTime @default(now())
  assignedBy String?
  expiresAt  DateTime?

  @@id([userId, roleId])
  @@index([tenantId])
  @@index([userId])
  @@map("user_roles")
}

model Session {
  id             String   @id @default(cuid())
  userId         String
  tenantId       String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId       String?
  ipAddress      String?
  userAgent      String?
  location       String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  expiresAt      DateTime
  lastActivityAt DateTime @default(now())

  @@index([userId])
  @@index([tenantId])
  @@map("sessions")
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tenantId   String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  family     String
  deviceId   String?
  ipAddress  String?
  isRevoked  Boolean   @default(false)
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime

  @@index([userId])
  @@index([family])
  @@map("refresh_tokens")
}

model OTPCode {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  type      OTPType
  isUsed    Boolean  @default(false)
  usedAt    DateTime?
  expiresAt DateTime
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("otp_codes")
}

model UserDevice {
  id           String    @id @default(cuid())
  userId       String
  tenantId     String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId     String    @unique
  deviceName   String?
  deviceType   String?
  platform     String?
  osVersion    String?
  appVersion   String?
  pushToken    String?
  isTrusted    Boolean   @default(false)
  isActive     Boolean   @default(true)
  lastSeenAt   DateTime?
  biometricKey String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([tenantId])
  @@map("user_devices")
}

// =============================================================================
// SITES & CUSTOMERS
// =============================================================================

model Site {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  customerId   String?
  customer     Customer?  @relation(fields: [customerId], references: [id])
  name         String
  code         String?
  type         SiteType   @default(FACILITY)
  status       SiteStatus @default(ACTIVE)
  address      String?
  city         String?
  state        String?
  country      String?
  postalCode   String?
  latitude     Decimal?   @db.Decimal(10, 7)
  longitude    Decimal?   @db.Decimal(10, 7)
  timezone     String?
  contactName  String?
  contactEmail String?
  contactPhone String?
  metadata     Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  users        UserSite[]
  incidents    Incident[]
  audits       Audit[]
  assets       Asset[]
  wasteRecords WasteRecord[]

  @@index([tenantId])
  @@index([customerId])
  @@map("sites")
}

model UserSite {
  userId String
  siteId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@id([userId, siteId])
  @@map("user_sites")
}

model Customer {
  id            String         @id @default(cuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  name          String
  code          String?
  email         String?
  phone         String?
  industry      String?
  country       String?
  status        CustomerStatus @default(ACTIVE)
  contractStart DateTime?
  contractEnd   DateTime?
  metadata      Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  sites     Site[]
  incidents Incident[]
  audits    Audit[]

  @@index([tenantId])
  @@map("customers")
}

// =============================================================================
// INCIDENTS & CAPA
// =============================================================================

model Incident {
  id               String           @id @default(cuid())
  tenantId         String
  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  siteId           String?
  site             Site?            @relation(fields: [siteId], references: [id])
  customerId       String?
  customer         Customer?        @relation(fields: [customerId], references: [id])
  reportedById     String
  reportedBy       User             @relation("IncidentReporter", fields: [reportedById], references: [id])
  assignedToId     String?
  assignedTo       User?            @relation("IncidentAssignee", fields: [assignedToId], references: [id])
  refNumber        String
  title            String
  description      String           @db.Text
  category         String
  subcategory      String?
  type             IncidentType     @default(INCIDENT)
  severity         IncidentSeverity @default(MEDIUM)
  status           IncidentStatus   @default(REPORTED)
  priority         Int              @default(3)
  occurredAt       DateTime
  reportedAt       DateTime         @default(now())
  dueDate          DateTime?
  closedAt         DateTime?
  location         String?
  injuryType       String?
  bodyPart         String?
  injuredPersons   Int              @default(0)
  immediateActions String?          @db.Text
  rootCause        String?          @db.Text
  isAnonymous      Boolean          @default(false)
  isNotifiable     Boolean          @default(false)
  notifiedAt       DateTime?
  latitude         Decimal?         @db.Decimal(10, 7)
  longitude        Decimal?         @db.Decimal(10, 7)
  metadata         Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  capas    IncidentCAPA[]
  evidence IncidentEvidence[]

  @@unique([tenantId, refNumber])
  @@index([tenantId])
  @@index([siteId])
  @@index([status])
  @@index([severity])
  @@index([occurredAt])
  @@map("incidents")
}

model IncidentCAPA {
  id            String       @id @default(cuid())
  tenantId      String
  incidentId    String
  incident      Incident     @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  type          CAPAType     @default(CORRECTIVE)
  title         String
  description   String       @db.Text
  assignedToId  String?
  assignedTo    User?        @relation("CAPAAssignee", fields: [assignedToId], references: [id])
  dueDate       DateTime?
  completedAt   DateTime?
  status        CAPAStatus   @default(OPEN)
  priority      CAPAPriority @default(MEDIUM)
  verifiedAt    DateTime?
  verifiedById  String?
  verifiedBy    User?        @relation("CAPAVerifier", fields: [verifiedById], references: [id])
  effectiveness String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([tenantId])
  @@index([incidentId])
  @@map("incident_capas")
}

model IncidentEvidence {
  id         String   @id @default(cuid())
  tenantId   String
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  type       String
  filename   String
  fileUrl    String
  fileSize   Int?
  mimeType   String?
  uploadedBy String
  uploadedAt DateTime @default(now())

  @@index([incidentId])
  @@map("incident_evidences")
}

// =============================================================================
// AUDITS & TEMPLATES
// =============================================================================

model AuditTemplate {
  id            String    @id @default(cuid())
  tenantId      String?
  tenant        Tenant?   @relation(fields: [tenantId], references: [id])
  name          String
  description   String?
  category      String?
  industry      String?
  version       String    @default("1.0")
  isActive      Boolean   @default(true)
  isPublic      Boolean   @default(false)
  estimatedMins Int?
  passingScore  Int?
  createdById   String?
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sections AuditTemplateSection[]
  audits   Audit[]

  @@index([tenantId])
  @@map("audit_templates")
}

model AuditTemplateSection {
  id          String                  @id @default(cuid())
  templateId  String
  template    AuditTemplate           @relation(fields: [templateId], references: [id], onDelete: Cascade)
  title       String
  description String?
  order       Int
  weight      Int                     @default(100)
  questions   AuditTemplateQuestion[]

  @@index([templateId])
  @@map("audit_template_sections")
}

model AuditTemplateQuestion {
  id             String               @id @default(cuid())
  sectionId      String
  section        AuditTemplateSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  text           String               @db.Text
  type           QuestionType
  isRequired     Boolean              @default(true)
  weight         Int                  @default(1)
  order          Int
  options        Json?
  expectedAnswer String?
  helpText       String?
  minValue       Float?
  maxValue       Float?
  unit           String?

  @@index([sectionId])
  @@map("audit_template_questions")
}

model Audit {
  id              String      @id @default(cuid())
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  templateId      String?
  template        AuditTemplate? @relation(fields: [templateId], references: [id])
  siteId          String?
  site            Site?       @relation(fields: [siteId], references: [id])
  customerId      String?
  customer        Customer?   @relation(fields: [customerId], references: [id])
  assignedToId    String?
  assignedTo      User?       @relation("AuditAssignee", fields: [assignedToId], references: [id])
  completedById   String?
  completedBy     User?       @relation("AuditCompletedBy", fields: [completedById], references: [id])
  refNumber       String
  title           String
  description     String?
  type            AuditType   @default(SCHEDULED)
  status          AuditStatus @default(DRAFT)
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  dueDate         DateTime?
  score           Float?
  maxScore        Float?
  percentage      Float?
  grade           String?
  passed          Boolean?
  findings        Int         @default(0)
  observations    Int         @default(0)
  nonConformances Int         @default(0)
  notes           String?     @db.Text
  conclusion      String?     @db.Text
  metadata        Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  responses    AuditResponse[]
  auditFindings AuditFinding[]

  @@unique([tenantId, refNumber])
  @@index([tenantId])
  @@index([siteId])
  @@index([status])
  @@map("audits")
}

model AuditResponse {
  id              String   @id @default(cuid())
  tenantId        String
  auditId         String
  audit           Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  questionId      String
  question        String
  questionType    String
  answer          String?  @db.Text
  numericAnswer   Float?
  booleanAnswer   Boolean?
  selectedOptions String[]
  score           Float?
  maxScore        Float?
  isCompliant     Boolean?
  notes           String?
  evidenceUrls    String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([auditId])
  @@map("audit_responses")
}

model AuditFinding {
  id           String          @id @default(cuid())
  tenantId     String
  auditId      String
  audit        Audit           @relation(fields: [auditId], references: [id], onDelete: Cascade)
  type         FindingType
  title        String
  description  String          @db.Text
  severity     FindingSeverity
  status       FindingStatus   @default(OPEN)
  dueDate      DateTime?
  assignedToId String?
  closedAt     DateTime?
  evidenceUrls String[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([auditId])
  @@map("audit_findings")
}

// =============================================================================
// TRAINING & INDUCTION
// =============================================================================

model Training {
  id              String         @id @default(cuid())
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  title           String
  description     String?        @db.Text
  category        String?
  type            TrainingType   @default(ONLINE)
  status          ContentStatus  @default(DRAFT)
  durationMins    Int?
  passingScore    Int?
  maxAttempts     Int?
  isRecurring     Boolean        @default(false)
  recurringDays   Int?
  validityDays    Int?
  coverImageUrl   String?
  createdById     String?
  metadata        Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  contents    TrainingContent[]
  questions   TrainingQuestion[]
  enrollments TrainingEnrollment[]

  @@index([tenantId])
  @@map("trainings")
}

model TrainingContent {
  id         String   @id @default(cuid())
  trainingId String
  training   Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  type       String
  title      String
  contentUrl String?
  durationSecs Int?
  order      Int
  isRequired Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([trainingId])
  @@map("training_contents")
}

model TrainingQuestion {
  id            String       @id @default(cuid())
  trainingId    String
  training      Training     @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  question      String       @db.Text
  type          QuestionType
  options       Json?
  correctAnswer String?
  explanation   String?
  points        Int          @default(1)
  order         Int

  @@index([trainingId])
  @@map("training_questions")
}

model TrainingEnrollment {
  id             String           @id @default(cuid())
  tenantId       String
  trainingId     String
  training       Training         @relation(fields: [trainingId], references: [id])
  userId         String
  user           User             @relation(fields: [userId], references: [id])
  status         EnrollmentStatus @default(ENROLLED)
  enrolledAt     DateTime         @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  expiresAt      DateTime?
  score          Float?
  passed         Boolean?
  attempts       Int              @default(0)
  certificateUrl String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([trainingId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("training_enrollments")
}

model Induction {
  id           String        @id @default(cuid())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  siteId       String?
  title        String
  description  String?
  status       ContentStatus @default(DRAFT)
  isRequired   Boolean       @default(true)
  validityDays Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  enrollments InductionEnrollment[]

  @@index([tenantId])
  @@map("inductions")
}

model InductionEnrollment {
  id          String           @id @default(cuid())
  tenantId    String
  inductionId String
  induction   Induction        @relation(fields: [inductionId], references: [id])
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  status      EnrollmentStatus @default(ENROLLED)
  completedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime         @default(now())

  @@unique([inductionId, userId])
  @@index([tenantId])
  @@map("induction_enrollments")
}

// =============================================================================
// PPE & ASSETS
// =============================================================================

model PPEItem {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  name            String
  category        String
  type            String?
  manufacturer    String?
  model           String?
  serialNumber    String?
  purchaseDate    DateTime?
  expiryDate      DateTime?
  status          PPEStatus @default(AVAILABLE)
  condition       String?
  storageLocation String?
  photoUrl        String?
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  assignments PPEAssignment[]

  @@index([tenantId])
  @@map("ppe_items")
}

model PPEAssignment {
  id         String    @id @default(cuid())
  tenantId   String
  ppeItemId  String
  ppeItem    PPEItem   @relation(fields: [ppeItemId], references: [id])
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  assignedAt DateTime  @default(now())
  returnedAt DateTime?
  condition  String?
  notes      String?

  @@index([tenantId])
  @@index([userId])
  @@map("ppe_assignments")
}

model Asset {
  id              String         @id @default(cuid())
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  siteId          String?
  site            Site?          @relation(fields: [siteId], references: [id])
  name            String
  assetTag        String?
  category        String
  type            String?
  make            String?
  model           String?
  serialNumber    String?
  purchaseDate    DateTime?
  purchaseCost    Decimal?       @db.Decimal(15, 2)
  warrantyExpiry  DateTime?
  status          AssetStatus    @default(OPERATIONAL)
  condition       AssetCondition @default(GOOD)
  location        String?
  department      String?
  nextServiceDate DateTime?
  lastServiceDate DateTime?
  qrCode          String?
  photoUrl        String?
  metadata        Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  assignments AssetAssignment[]

  @@index([tenantId])
  @@index([siteId])
  @@map("assets")
}

model AssetAssignment {
  id         String    @id @default(cuid())
  tenantId   String
  assetId    String
  asset      Asset     @relation(fields: [assetId], references: [id])
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  assignedAt DateTime  @default(now())
  returnedAt DateTime?
  notes      String?

  @@index([tenantId])
  @@map("asset_assignments")
}

// =============================================================================
// WASTE MANAGEMENT
// =============================================================================

model WasteRecord {
  id             String      @id @default(cuid())
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  siteId         String?
  site           Site?       @relation(fields: [siteId], references: [id])
  category       String
  type           String?
  description    String?
  quantity       Decimal     @db.Decimal(15, 4)
  unit           String
  disposalMethod String?
  contractor     String?
  manifestNumber String?
  disposedAt     DateTime
  status         WasteStatus @default(PENDING)
  cost           Decimal?    @db.Decimal(15, 2)
  notes          String?
  metadata       Json?
  createdById    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([tenantId])
  @@index([siteId])
  @@map("waste_records")
}

// =============================================================================
// DOCUMENTS
// =============================================================================

model Document {
  id             String         @id @default(cuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  uploadedById   String
  uploadedBy     User           @relation(fields: [uploadedById], references: [id])
  title          String
  description    String?
  category       String?
  tags           String[]
  type           String?
  status         DocumentStatus @default(DRAFT)
  version        String         @default("1.0")
  fileUrl        String
  storageKey     String?
  filename       String
  fileSize       Int?
  mimeType       String?
  checksum       String?
  isPublic       Boolean        @default(false)
  expiryDate     DateTime?
  reviewDate     DateTime?
  approvedById   String?
  approvedAt     DateTime?
  metadata       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  versions DocumentVersion[]

  @@index([tenantId])
  @@index([uploadedById])
  @@map("documents")
}

model DocumentVersion {
  id           String   @id @default(cuid())
  documentId   String
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version      String
  fileUrl      String
  filename     String
  fileSize     Int?
  changeSummary String?
  uploadedById String
  createdAt    DateTime @default(now())

  @@index([documentId])
  @@map("document_versions")
}

// =============================================================================
// NOTIFICATIONS
// =============================================================================

model NotificationTemplate {
  id          String   @id @default(cuid())
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  event       String
  channel     String
  subject     String?
  bodyHtml    String?  @db.Text
  bodyText    String?  @db.Text
  variables   String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, event, channel])
  @@map("notification_templates")
}

model Notification {
  id        String             @id @default(cuid())
  tenantId  String
  tenant    Tenant             @relation(fields: [tenantId], references: [id])
  userId    String
  user      User               @relation(fields: [userId], references: [id])
  type      String
  title     String
  message   String
  channel   String             @default("in-app")
  status    NotificationStatus @default(PENDING)
  data      Json?
  readAt    DateTime?
  sentAt    DateTime?
  failedAt  DateTime?
  error     String?
  createdAt DateTime           @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@map("notifications")
}

// =============================================================================
// REPORTS
// =============================================================================

model Report {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id])
  title         String
  type          ReportType
  status        ReportStatus @default(PENDING)
  parameters    Json         @default("{}")
  filters       Json         @default("{}")
  fileUrl       String?
  generatedAt   DateTime?
  error         String?
  requestedById String?
  createdAt     DateTime     @default(now())

  @@index([tenantId])
  @@index([requestedById])
  @@map("reports")
}

// =============================================================================
// SYSTEM & COMPLIANCE
// =============================================================================

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String?
  tenant     Tenant?  @relation(fields: [tenantId], references: [id])
  userId     String?
  sessionId  String?
  action     String
  resource   String
  resourceId String?
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  deviceId   String?
  requestId  String?
  status     String   @default("SUCCESS")
  error      String?
  durationMs Int?
  hash       String
  prevHash   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ActivityLog {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  description String
  resource   String?
  resourceId String?
  ipAddress  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

model Feedback {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  userId     String?
  type       String
  subject    String
  message    String   @db.Text
  rating     Int?
  status     String   @default("OPEN")
  resolvedAt DateTime?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@map("feedbacks")
}

model ApiKey {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  userId      String?
  name        String
  keyHash     String    @unique
  permissions String[]
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@index([tenantId])
  @@map("api_keys")
}

model Webhook {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  url            String
  events         String[]
  secret         String
  isActive       Boolean   @default(true)
  customHeaders  Json?
  maxRetries     Int       @default(3)
  timeoutMs      Int       @default(30000)
  failureCount   Int       @default(0)
  lastCalledAt   DateTime?
  description    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([tenantId])
  @@map("webhooks")
}

